# =============================================================================
# PayMob Demo - Environment Configuration
# =============================================================================
# Get your credentials from: https://accept.paymob.com/portal2/en/dashboard

# -----------------------------------------------------------------------------
# PayMob API Configuration (Required for real payments)
# -----------------------------------------------------------------------------

# API Key - From Settings -> Account Settings -> API Key
PAYMOB_API_KEY=your_paymob_api_key_here

# Merchant ID - From Settings -> Account Settings -> Merchant ID
PAYMOB_MERCHANT_ID=your_merchant_id_here

# Integration ID - From Settings -> Payment Methods -> Click your card integration
# This is used when generating the payment key
PAYMOB_INTEGRATION_ID=your_integration_id_here

# Iframe ID - From Settings -> Payment Methods -> Your Integration -> Iframe ID
# This is used in the checkout URL (sometimes same as Integration ID)
PAYMOB_IFRAME_ID=your_iframe_id_here

# HMAC Secret - From Settings -> Account Settings -> HMAC Security
# Used to verify webhook signatures for security
PAYMOB_HMAC_SECRET=your_hmac_secret_here

# PayMob Base URL
PAYMOB_BASE_URL=https://accept.paymobsolutions.com

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

PORT=3000

# Your server's public URL (needed for webhooks)
# For local development with ngrok: https://your-ngrok-url.ngrok.io
SERVER_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Demo Mode
# -----------------------------------------------------------------------------

# Set to "true" to use demo simulation, "false" for real PayMob payments
DEMO_MODE=false